# Telegram Content Summarizer Bot - Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# TELEGRAM
# ===========================================
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ===========================================
# OPENROUTER (LLM)
# ===========================================
# Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# Model to use (options below)
# openai/gpt-4o-mini (recommended - fast & cheap)
# openai/gpt-4o (more capable)
# anthropic/claude-3.5-sonnet (alternative)
OPENROUTER_MODEL=openai/gpt-4o-mini

# ===========================================
# SUPADATA (YouTube Transcripts)
# ===========================================
# Get from https://supadata.ai
SUPADATA_API_KEY=your_supadata_key_here

# ===========================================
# AIRTABLE (Database)
# ===========================================
# Get from https://airtable.com/create/tokens
AIRTABLE_API_KEY=pat_your_key_here

# Find in your base URL: airtable.com/appXXXXXXXX/...
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Table name (default: Summaries)
AIRTABLE_TABLE_NAME=Summaries

# ===========================================
# N8N CLOUD (Workflow Automation)
# ===========================================
# Get from https://n8n.io (sign up for n8n Cloud)
N8N_INSTANCE_URL=https://your-name.app.n8n.cloud
# Get from: Settings -> API in your n8n Cloud instance
N8N_API_KEY=your_n8n_api_key_here
# Your workflow ID (created after importing the workflow)
N8N_WORKFLOW_ID=your_workflow_id_here
N8N_WORKFLOW_URL=https://your-name.app.n8n.cloud/workflow/your_workflow_id

# ===========================================
# OPTIONAL: Jina Reader
# ===========================================
# Jina Reader is free and doesn't require an API key
# But you can add one for higher rate limits
# JINA_API_KEY=jina_your_key_here
